\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {CRITIC Criterion Weights}, 2011--2024. Time-averaged weights spanning all 14 survey years. Weights represent the relative information content (variance and independence) of each criterion, derived from the hierarchical two-level \textsc  {critic}\xspace  procedure.}}{42}{table.caption.10}\protected@file@percent }
\newlabel{tab:weight-distribution}{{5}{42}{\textbf {CRITIC Criterion Weights}, 2011--2024. Time-averaged weights spanning all 14 survey years. Weights represent the relative information content (variance and independence) of each criterion, derived from the hierarchical two-level \CRITIC procedure}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {CRITIC Sub-Criterion Weight Radars}, 2011--2024. Radar polygons display the normalized contribution of individual sub-criteria (SC11--SC83) within each of the eight governance dimensions across fourteen survey years. Radial distance from center encodes normalized weight magnitude; each vertex corresponds to a sub-criterion. The evolution from 2011--2017 (six criteria, $p=21$ sub-criteria) to 2018--2024 (eight criteria, $p=29$ sub-criteria) reflects the structural index redesign and hierarchical rebalancing under the two-level \textsc  {critic}\xspace  framework.}}{44}{figure.caption.11}\protected@file@percent }
\newlabel{fig:weight-radar}{{1}{44}{\textbf {CRITIC Sub-Criterion Weight Radars}, 2011--2024. Radar polygons display the normalized contribution of individual sub-criteria (SC11--SC83) within each of the eight governance dimensions across fourteen survey years. Radial distance from center encodes normalized weight magnitude; each vertex corresponds to a sub-criterion. The evolution from 2011--2017 (six criteria, $p=21$ sub-criteria) to 2018--2024 (eight criteria, $p=29$ sub-criteria) reflects the structural index redesign and hierarchical rebalancing under the two-level \CRITIC framework}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {CRITIC Sub-Criterion Weight Heatmap}, 2011--2024. Temporal evolution of 29 sub-criterion weights across fourteen survey years, encoded as a matrix with color intensity proportional to weight value (yellow $\approx $ 0.001, red $\approx $ 0.04). Vertical dashed lines delineate criterion boundaries (C01 through C08). The structural expansion in 2018 introduces new sub-criteria (SC71, SC72, SC73, SC81, SC82, SC83) visible as previously-zero columns that acquire positive weights. The baseline sub-criteria (SC11--SC64) demonstrate persistent color gradients, indicating stable within-criterion prioritization.}}{45}{figure.caption.12}\protected@file@percent }
\newlabel{fig:weight-heatmap}{{2}{45}{\textbf {CRITIC Sub-Criterion Weight Heatmap}, 2011--2024. Temporal evolution of 29 sub-criterion weights across fourteen survey years, encoded as a matrix with color intensity proportional to weight value (yellow $\approx $ 0.001, red $\approx $ 0.04). Vertical dashed lines delineate criterion boundaries (C01 through C08). The structural expansion in 2018 introduces new sub-criteria (SC71, SC72, SC73, SC81, SC82, SC83) visible as previously-zero columns that acquire positive weights. The baseline sub-criteria (SC11--SC64) demonstrate persistent color gradients, indicating stable within-criterion prioritization}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.1.2}Weighting Result Analysis and Validation}{46}{subsubsection.3.1.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Temporal Stability Metrics: Spearman's Rho and Kendall's W}, 2011--2024. Window-based analysis using 5-year sliding windows with 1-year overlap. Spearman's $\rho $ measures rank correlation of criterion weights between adjacent windows; Kendall's $W$ provides an omnibus concordance statistic across all ten windows.}}{46}{table.caption.13}\protected@file@percent }
\newlabel{tab:weight-temporal-stability}{{6}{46}{\textbf {Temporal Stability Metrics: Spearman's Rho and Kendall's W}, 2011--2024. Window-based analysis using 5-year sliding windows with 1-year overlap. Spearman's $\rho $ measures rank correlation of criterion weights between adjacent windows; Kendall's $W$ provides an omnibus concordance statistic across all ten windows}{table.caption.13}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Criterion Weight Coefficient of Variation}, 2011--2024. Relative volatility in criterion weights across all fourteen survey years. $\mathrm  {CV} = \sigma / \mu $ where $\sigma $ is the standard deviation and $\mu $ is the mean weight.}}{48}{table.caption.14}\protected@file@percent }
\newlabel{tab:weight-stability-cv}{{7}{48}{\textbf {Criterion Weight Coefficient of Variation}, 2011--2024. Relative volatility in criterion weights across all fourteen survey years. $\mathrm {CV} = \sigma / \mu $ where $\sigma $ is the standard deviation and $\mu $ is the mean weight}{table.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces \textbf  {Weight Sensitivity to Data Perturbations}: Monte Carlo Robustness Analysis. Three perturbation tiers represent different magnitudes of random noise injection into criterion scores. Robustness score reflects the proportion of 10,000 Monte Carlo replications in which the criterion rank order is preserved.}}{49}{table.caption.15}\protected@file@percent }
\newlabel{tab:weight-sensitivity}{{8}{49}{\textbf {Weight Sensitivity to Data Perturbations}: Monte Carlo Robustness Analysis. Three perturbation tiers represent different magnitudes of random noise injection into criterion scores. Robustness score reflects the proportion of 10,000 Monte Carlo replications in which the criterion rank order is preserved}{table.caption.15}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Rankings Results}{49}{subsection.3.2}\protected@file@percent }
\newlabel{subsec:results_rankings}{{3.2}{49}{Rankings Results}{subsection.3.2}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.1}Multi-Method MCDM Ranking Results}{49}{subsubsection.3.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Top 15 Provinces by Composite Governance Ranking}, 2024. Bar chart displaying the final composite governance scores for the 15 highest-ranked provinces in 2024, derived from \textsc  {critic}\xspace  -weighted aggregation across six MCDM methods. The composite score integrates: (1)~within-method aggregation across criteria using criterion-specific CRITIC weights, and (2)~across-method aggregation using method weights estimated via bootstrap resampling and stability-adjusted averaging. Provinces in the 0.70--0.85 range represent the governance excellence tier; scores above 0.85 are exceptional. P39, leading the 2024 rankings, achieves a composite score of 0.7812, indicating robust citizen-perceived governance quality across multiple dimensions relative to provincial peers.}}{50}{figure.caption.16}\protected@file@percent }
\newlabel{fig:mcdm-2024-top15}{{3}{50}{\textbf {Top 15 Provinces by Composite Governance Ranking}, 2024. Bar chart displaying the final composite governance scores for the 15 highest-ranked provinces in 2024, derived from \CRITIC -weighted aggregation across six MCDM methods. The composite score integrates: (1)~within-method aggregation across criteria using criterion-specific CRITIC weights, and (2)~across-method aggregation using method weights estimated via bootstrap resampling and stability-adjusted averaging. Provinces in the 0.70--0.85 range represent the governance excellence tier; scores above 0.85 are exceptional. P39, leading the 2024 rankings, achieves a composite score of 0.7812, indicating robust citizen-perceived governance quality across multiple dimensions relative to provincial peers}{figure.caption.16}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces \textbf  {Top-Ranked Province per Year by Six MCDM Methods}, 2011--2024. For each survey year, the province achieving the highest composite governance score is identified, along with its respective scores under each of the six MCDM methodologies. The consistency of top-ranked provinces across all six methods validates the consensus approach.}}{51}{table.caption.17}\protected@file@percent }
\newlabel{tab:top-province-per-year}{{9}{51}{\textbf {Top-Ranked Province per Year by Six MCDM Methods}, 2011--2024. For each survey year, the province achieving the highest composite governance score is identified, along with its respective scores under each of the six MCDM methodologies. The consistency of top-ranked provinces across all six methods validates the consensus approach}{table.caption.17}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.2}Ranking Result Analysis and Validation}{51}{subsubsection.3.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Score Distribution of Six MCDM Methods}, 2011--2024. Box-and-whisker plots illustrate the annual distribution of composite governance scores for each method. The plot displays the median (central orange line), lower and upper quartiles (box bounds), and extreme values (whiskers) across all 882 province--year observations. The homogeneity of distributions across the six methods---visible as substantial overlap in box positions and whisker ranges---provides further visual evidence of methodological convergence. Slight right skews (visible as longer upper whiskers and higher maximum values) reflect a small population of exceptionally well-governed provinces, consistent with typical governance patterns where a few high-performing jurisdictions emerge from the provincial distribution. The absence of substantial asymmetry or bimodality indicates that governance performance is distributed approximately continuously across the province population, supporting the use of a single unified ranking order rather than discrete governance tiers.}}{52}{figure.caption.18}\protected@file@percent }
\newlabel{fig:mcdm-distribution}{{4}{52}{\textbf {Score Distribution of Six MCDM Methods}, 2011--2024. Box-and-whisker plots illustrate the annual distribution of composite governance scores for each method. The plot displays the median (central orange line), lower and upper quartiles (box bounds), and extreme values (whiskers) across all 882 province--year observations. The homogeneity of distributions across the six methods---visible as substantial overlap in box positions and whisker ranges---provides further visual evidence of methodological convergence. Slight right skews (visible as longer upper whiskers and higher maximum values) reflect a small population of exceptionally well-governed provinces, consistent with typical governance patterns where a few high-performing jurisdictions emerge from the provincial distribution. The absence of substantial asymmetry or bimodality indicates that governance performance is distributed approximately continuously across the province population, supporting the use of a single unified ranking order rather than discrete governance tiers}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Inter-Method Agreement Matrix}: Spearman Rank Correlation between Six MCDM Methods. Cell colors encode pairwise Spearman correlation coefficients ($\rho $) computed across all 882 province--year observations. Values near 1.0 (dark red) indicate perfect or near-perfect rank alignment; off-diagonal values illustrate methodological convergence. Key observations: COPRAS and EDAS exhibit perfect agreement ($\rho = 1.00$), suggesting mathematical equivalence on this dataset; TOPSIS and PROMETHEE achieve near-perfect correlation ($\rho = 0.98$), while all inter-method pairs sustain minimum correlations $\rho \geq 0.89$. The consistent saturation of red coloring across the matrix signals robust consensus on province ordering independent of mathematical formalism.}}{53}{figure.caption.19}\protected@file@percent }
\newlabel{fig:mcdm-agreement}{{5}{53}{\textbf {Inter-Method Agreement Matrix}: Spearman Rank Correlation between Six MCDM Methods. Cell colors encode pairwise Spearman correlation coefficients ($\rho $) computed across all 882 province--year observations. Values near 1.0 (dark red) indicate perfect or near-perfect rank alignment; off-diagonal values illustrate methodological convergence. Key observations: COPRAS and EDAS exhibit perfect agreement ($\rho = 1.00$), suggesting mathematical equivalence on this dataset; TOPSIS and PROMETHEE achieve near-perfect correlation ($\rho = 0.98$), while all inter-method pairs sustain minimum correlations $\rho \geq 0.89$. The consistent saturation of red coloring across the matrix signals robust consensus on province ordering independent of mathematical formalism}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Pairwise Score Comparison Matrix for Six MCDM Methods}. Each cell shows the relationship between scores assigned by a pair of methods across all 882 province--year observations. Diagonal cells display histograms of the score distribution for each individual method. The strong linearity in off-diagonal scatterplots (particularly visible in COPRAS--EDAS, TOPSIS--PROMETHEE, and other pairs) confirms not only rank correlation but also score magnitude concordance. Minor deviations from perfect linearity highlight methodological nuances: certain methods may assign higher scores to exceptionally well-governed provinces (visible as slight curvature in upper-right regions of some panels) or suppress scores at the lower tail (visible as curvature in lower-left regions). These nuances, while mathematically interesting, do not substantially disrupt the provincial orderings, as the correlation analysis established.}}{55}{figure.caption.20}\protected@file@percent }
\newlabel{fig:mcdm-pairwise-scatter}{{6}{55}{\textbf {Pairwise Score Comparison Matrix for Six MCDM Methods}. Each cell shows the relationship between scores assigned by a pair of methods across all 882 province--year observations. Diagonal cells display histograms of the score distribution for each individual method. The strong linearity in off-diagonal scatterplots (particularly visible in COPRAS--EDAS, TOPSIS--PROMETHEE, and other pairs) confirms not only rank correlation but also score magnitude concordance. Minor deviations from perfect linearity highlight methodological nuances: certain methods may assign higher scores to exceptionally well-governed provinces (visible as slight curvature in upper-right regions of some panels) or suppress scores at the lower tail (visible as curvature in lower-left regions). These nuances, while mathematically interesting, do not substantially disrupt the provincial orderings, as the correlation analysis established}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Ranking Discriminatory Power via Score Inter-Quartile Range}. Bar chart quantifying each method's ability to differentiate among provinces, measured as the inter-quartile range (IQR = Q75---Q25) of composite scores across all 882 province--year observations. Higher IQR values indicate greater score dispersion and thus finer discrimination among middle-ranking provinces. \textbf  {PROMETHEE} attains the maximum discriminatory power with $\mathrm  {IQR} = 0.2685$, reflecting its outranking logic which amplifies fine distinctions in pairwise province comparisons. \textbf  {EDAS} follows with $\mathrm  {IQR} = 0.2416$, while \textbf  {TOPSIS} provides the most conservative discrimination ($\mathrm  {IQR} = 0.2123$), consistent with its distance-based approach which can compress scores toward the middle-range reference point. The population median IQR of 0.2296 indicates that all methods cluster tightly around a common discriminatory threshold, distributing approximately 23 percentage points of score variance from lower quartile to upper quartile. This consistency across methods suggests that the discriminatory architecture is fundamentally constrained by the underlying governance data structure rather than shaped by algorithmic idiosyncrasy.}}{56}{figure.caption.21}\protected@file@percent }
\newlabel{fig:mcdm-discriminatory}{{7}{56}{\textbf {Ranking Discriminatory Power via Score Inter-Quartile Range}. Bar chart quantifying each method's ability to differentiate among provinces, measured as the inter-quartile range (IQR = Q75---Q25) of composite scores across all 882 province--year observations. Higher IQR values indicate greater score dispersion and thus finer discrimination among middle-ranking provinces. \textbf {PROMETHEE} attains the maximum discriminatory power with $\mathrm {IQR} = 0.2685$, reflecting its outranking logic which amplifies fine distinctions in pairwise province comparisons. \textbf {EDAS} follows with $\mathrm {IQR} = 0.2416$, while \textbf {TOPSIS} provides the most conservative discrimination ($\mathrm {IQR} = 0.2123$), consistent with its distance-based approach which can compress scores toward the middle-range reference point. The population median IQR of 0.2296 indicates that all methods cluster tightly around a common discriminatory threshold, distributing approximately 23 percentage points of score variance from lower quartile to upper quartile. This consistency across methods suggests that the discriminatory architecture is fundamentally constrained by the underlying governance data structure rather than shaped by algorithmic idiosyncrasy}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Ranking Stability via Cross-Criteria Spearman Correlation}. Measures the extent to which province orderings remain consistent across different governance criteria. Each bar reports the average pairwise Spearman correlation between criterion-specific rankings for a given method. \textbf  {PROMETHEE} exhibits the highest stability coefficient ($\rho = 0.397$), indicating that provinces ranked high in, for example, transparency tend to maintain elevated rankings in accountability, corruption control, and other domains. \textbf  {VIKOR} displays comparatively lower cross-criteria coherence ($\rho = 0.303$), though this remains substantially above random expectation (where $\rho \approx 0$). The population median cross-criteria correlation of $\rho = 0.356$ represents typical consistency across methods and reflects genuine governance structure: provinces with strong performance in one dimension tend to exhibit correlated strength in others, a pattern attributable to underlying provincial governance capacity and institutional quality. The positive but non-perfect correlations confirm that despite overall governance coherence, substantial variation exists in provincial performance profiles---some provinces excel in specific dimensions while lagging in others.}}{57}{figure.caption.22}\protected@file@percent }
\newlabel{fig:mcdm-stability}{{8}{57}{\textbf {Ranking Stability via Cross-Criteria Spearman Correlation}. Measures the extent to which province orderings remain consistent across different governance criteria. Each bar reports the average pairwise Spearman correlation between criterion-specific rankings for a given method. \textbf {PROMETHEE} exhibits the highest stability coefficient ($\rho = 0.397$), indicating that provinces ranked high in, for example, transparency tend to maintain elevated rankings in accountability, corruption control, and other domains. \textbf {VIKOR} displays comparatively lower cross-criteria coherence ($\rho = 0.303$), though this remains substantially above random expectation (where $\rho \approx 0$). The population median cross-criteria correlation of $\rho = 0.356$ represents typical consistency across methods and reflects genuine governance structure: provinces with strong performance in one dimension tend to exhibit correlated strength in others, a pattern attributable to underlying provincial governance capacity and institutional quality. The positive but non-perfect correlations confirm that despite overall governance coherence, substantial variation exists in provincial performance profiles---some provinces excel in specific dimensions while lagging in others}{figure.caption.22}{}}
