\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {CRITIC Sub-Criterion Weight Radars}, 2011--2024. Radar plots display the relative contribution of individual sub-criteria to each of the eight governance dimensions across the 14-year observation period. Radial distance represents normalized weight magnitude; each polygon vertex corresponds to a sub-criterion label (SC11--SC83). The visual evolution from 2011--2017 (six criteria, partial sub-criterion set) to 2018--2024 (eight criteria, complete set) reflects the hierarchical restructuring following the introduction of C07 and C08.}}{43}{figure.caption.12}\protected@file@percent }
\newlabel{fig:weight-radar}{{1}{43}{\textbf {CRITIC Sub-Criterion Weight Radars}, 2011--2024. Radar plots display the relative contribution of individual sub-criteria to each of the eight governance dimensions across the 14-year observation period. Radial distance represents normalized weight magnitude; each polygon vertex corresponds to a sub-criterion label (SC11--SC83). The visual evolution from 2011--2017 (six criteria, partial sub-criterion set) to 2018--2024 (eight criteria, complete set) reflects the hierarchical restructuring following the introduction of C07 and C08}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {CRITIC Sub-Criterion Weight Heatmap}, 2011--2024 Temporal Evolution. Cell colors encode weight intensity (yellow = low, red = high) for each sub-criterion (SC column) in each year (row). Vertical dashed lines delineate criterion boundaries (C01 through C08). The structural break at year-row 2018 marks the introduction of new sub-criteria (SC71, SC72, SC73, SC81, SC82, SC83), visible as new columns with sparse early values.}}{44}{figure.caption.13}\protected@file@percent }
\newlabel{fig:weight-heatmap}{{2}{44}{\textbf {CRITIC Sub-Criterion Weight Heatmap}, 2011--2024 Temporal Evolution. Cell colors encode weight intensity (yellow = low, red = high) for each sub-criterion (SC column) in each year (row). Vertical dashed lines delineate criterion boundaries (C01 through C08). The structural break at year-row 2018 marks the introduction of new sub-criteria (SC71, SC72, SC73, SC81, SC82, SC83), visible as new columns with sparse early values}{figure.caption.13}{}}
