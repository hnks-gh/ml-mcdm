\newlabel{subsec:results_rankings}{{3.2}{44}{MCDM Rankings}{subsection.3.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Top 15 Provinces by Composite Governance Ranking}, 2024. Scores obtained via CRITIC-weighted aggregation of six MCDM methods (TOPSIS, VIKOR, PROMETHEE, COPRAS, EDAS, SAW). Composite score computed as weighted mean across methods using observed variance-weighted meta-weights.}}{46}{table.caption.14}\protected@file@percent }
\newlabel{tab:mcdm-2024-top15}{{7}{46}{\textbf {Top 15 Provinces by Composite Governance Ranking}, 2024. Scores obtained via CRITIC-weighted aggregation of six MCDM methods (TOPSIS, VIKOR, PROMETHEE, COPRAS, EDAS, SAW). Composite score computed as weighted mean across methods using observed variance-weighted meta-weights}{table.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Inter-Method Agreement Matrix}: Spearman Rank Correlation between Six MCDM Methods. Each cell represents the pairwise Spearman correlation coefficient ($\rho $) computed across all 882 province--year observations. Values near 1.0 (dark red) indicate perfect or near-perfect rank alignment; off-diagonal values illustrate high methodological convergence. Perfect agreement (1.00) is observed for COPRAS--EDAS, and correlations of 0.94--0.99 characterize most pair-wise comparisons, confirming robust consensus on province ordering independent of algorithmic choice.}}{47}{figure.caption.15}\protected@file@percent }
\newlabel{fig:mcdm-agreement}{{3}{47}{\textbf {Inter-Method Agreement Matrix}: Spearman Rank Correlation between Six MCDM Methods. Each cell represents the pairwise Spearman correlation coefficient ($\rho $) computed across all 882 province--year observations. Values near 1.0 (dark red) indicate perfect or near-perfect rank alignment; off-diagonal values illustrate high methodological convergence. Perfect agreement (1.00) is observed for COPRAS--EDAS, and correlations of 0.94--0.99 characterize most pair-wise comparisons, confirming robust consensus on province ordering independent of algorithmic choice}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Ranking Discriminatory Power via Score Inter-Quartile Range}: Bar chart quantifying each method's ability to differentiate among provinces. The IQR (difference between 75th and 25th percentiles) is plotted for each method; higher values indicate greater score dispersion and thus finer discrimination among middle-ranking provinces. PROMETHEE attains the maximum IQR ($0.2685$), while TOPSIS provides the most conservative differentiation ($0.2123$). The dashed median line ($0.2296$) shows that all methods cluster tightly around a common discriminatory threshold.}}{48}{figure.caption.16}\protected@file@percent }
\newlabel{fig:mcdm-discriminatory}{{4}{48}{\textbf {Ranking Discriminatory Power via Score Inter-Quartile Range}: Bar chart quantifying each method's ability to differentiate among provinces. The IQR (difference between 75th and 25th percentiles) is plotted for each method; higher values indicate greater score dispersion and thus finer discrimination among middle-ranking provinces. PROMETHEE attains the maximum IQR ($0.2685$), while TOPSIS provides the most conservative differentiation ($0.2123$). The dashed median line ($0.2296$) shows that all methods cluster tightly around a common discriminatory threshold}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Ranking Stability via Cross-Criteria Spearman Correlation}: Measures the extent to which province orderings remain consistent across different governance criteria. Each bar reports the average pairwise Spearman correlation between criterion-specific rankings for a given method. PROMETHEE exhibits the highest stability ($\rho = 0.397$), indicating that provinces ranked high in one criterion tend to maintain elevated ranks across other criteria. VIKOR displays lower cross-criteria coherence ($\rho = 0.303$), though this remains substantially above random expectation. The population median ($\rho = 0.356$) represents typical consistency across methods.}}{48}{figure.caption.17}\protected@file@percent }
\newlabel{fig:mcdm-stability}{{5}{48}{\textbf {Ranking Stability via Cross-Criteria Spearman Correlation}: Measures the extent to which province orderings remain consistent across different governance criteria. Each bar reports the average pairwise Spearman correlation between criterion-specific rankings for a given method. PROMETHEE exhibits the highest stability ($\rho = 0.397$), indicating that provinces ranked high in one criterion tend to maintain elevated ranks across other criteria. VIKOR displays lower cross-criteria coherence ($\rho = 0.303$), though this remains substantially above random expectation. The population median ($\rho = 0.356$) represents typical consistency across methods}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Score Distribution of Six MCDM Methods}, 2011--2024. Box-and-whisker plots illustrate the annual distribution of composite governance scores for each method, aggregated across all 63 provinces and all 14 years. The median (orange line), quartiles (box bounds), and extreme scores (whiskers) show that all six methods cluster tightly around a central distribution, supporting the convergence hypothesis. Slight right skews reflect a small population of exceptionally well-governed provinces across the entire dataset.}}{49}{figure.caption.18}\protected@file@percent }
\newlabel{fig:mcdm-distribution}{{6}{49}{\textbf {Score Distribution of Six MCDM Methods}, 2011--2024. Box-and-whisker plots illustrate the annual distribution of composite governance scores for each method, aggregated across all 63 provinces and all 14 years. The median (orange line), quartiles (box bounds), and extreme scores (whiskers) show that all six methods cluster tightly around a central distribution, supporting the convergence hypothesis. Slight right skews reflect a small population of exceptionally well-governed provinces across the entire dataset}{figure.caption.18}{}}
