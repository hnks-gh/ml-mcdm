\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Stacked Generalization Meta-Weights. Optimal weights $\mathbf  {w} = (w_1, \ldots  , w_K)$ are estimated from out-of-fold base model predictions via ridge regression on the validation set. Weights are constrained to $[0, 1]$ with $\DOTSB \sum@ \slimits@ _k w_k = 1$. }}{60}{table.caption.27}\protected@file@percent }
\newlabel{tab:meta_weights}{{12}{60}{Stacked Generalization Meta-Weights. Optimal weights $\mathbf {w} = (w_1, \ldots , w_K)$ are estimated from out-of-fold base model predictions via ridge regression on the validation set. Weights are constrained to $[0, 1]$ with $\sum _k w_k = 1$}{table.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Meta-Learner Base Model Contribution Weights}. The ensemble's optimal weights for combining base learner predictions, learned through ridge-regularized least squares on out-of-fold residuals. CatBoost contributes the plurality ($45.2\%$), leveraging its capacity for multi-output tree fitting and cross-criterion correlation capture. Bayesian Ridge provides the second-largest contribution ($29.9\%$), offering linear approximation and uncertainty quantification. Support Vector Regression and ElasticNet contribute $14.5\%$ and $10.3\%$ respectively, supplying kernel-based robustness and regularized linear modeling. The weight distribution reflects each model's marginal value in the ensemble context, where complementarity matters more than individual excellence.}}{61}{figure.caption.28}\protected@file@percent }
\newlabel{fig:forecast_meta_weights}{{9}{61}{\textbf {Meta-Learner Base Model Contribution Weights}. The ensemble's optimal weights for combining base learner predictions, learned through ridge-regularized least squares on out-of-fold residuals. CatBoost contributes the plurality ($45.2\%$), leveraging its capacity for multi-output tree fitting and cross-criterion correlation capture. Bayesian Ridge provides the second-largest contribution ($29.9\%$), offering linear approximation and uncertainty quantification. Support Vector Regression and ElasticNet contribute $14.5\%$ and $10.3\%$ respectively, supplying kernel-based robustness and regularized linear modeling. The weight distribution reflects each model's marginal value in the ensemble context, where complementarity matters more than individual excellence}{figure.caption.28}{}}
